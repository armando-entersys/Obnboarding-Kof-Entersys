# Database
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_password
POSTGRES_SERVER=your_host
POSTGRES_DB=your_db
POSTGRES_PORT=5432

# JWT
SECRET_KEY=your_secret_key

# Smartsheet
SMARTSHEET_ACCESS_TOKEN=your_token
MIDDLEWARE_API_KEY=your_api_key
SHEET_ID=7060277951418244

# Google Cloud Storage
GCS_BUCKET_NAME=entersys-onboarding-photos
GCS_PROJECT_ID=mi-infraestructura-web

# Google Service Account (for Gmail API and GCS)
# Place service-account.json in ./credentials/ directory
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/service-account.json

# Email (Gmail)
SMTP_USER=your_email@entersys.mx
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=no-reply@entersys.mx
